# --- Database (required) ---
# Local: Neon / Supabase / Docker. Vercel: use the provider's pooled/serverless URL when offered.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/returnee

# --- XRPL (optional; omit for simulated tx hashes) ---
XRPL_SERVER_URL=wss://s.altnet.rippletest.net:51233
XRPL_WALLET_SEED=
XRPL_DESTINATION_ADDRESS=

# --- Auth (required) ---
# Same random string for both (middleware JWT + NextAuth signing)
AUTH_SECRET=
NEXTAUTH_SECRET=
# Local: http://localhost:3000 | Production: https://your-app.vercel.app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated emails; role = admin / courier / resident (default)
ADMIN_EMAILS=
COURIER_EMAILS=
